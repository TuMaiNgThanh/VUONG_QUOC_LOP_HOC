# Firebase web config (recommended if you later move config out of source files)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Google Drive upload API endpoint (optional)
# Leave empty to use Firebase Storage directly (no Cloud Run billing required).
# Example:
# VITE_DRIVE_UPLOAD_ENDPOINT=https://<your-upload-api>/upload
VITE_DRIVE_UPLOAD_ENDPOINT=

# Cloudinary upload (optional, no backend needed when using unsigned preset)
# IMPORTANT: Do NOT expose CLOUDINARY_API_SECRET in frontend.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
