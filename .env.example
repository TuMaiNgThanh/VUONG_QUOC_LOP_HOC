# Firebase web config (recommended if you later move config out of source files)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Google Drive upload API endpoint (required in production when replacing Firebase Storage)
# Example:
# VITE_DRIVE_UPLOAD_ENDPOINT=https://<your-upload-api>/upload
VITE_DRIVE_UPLOAD_ENDPOINT=
